{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Trion": {
      "Folder": "Logs",
      "WriteToConsole": true,
      "WriteToFile": true,
      "ShowInfo": true,
      "ShowSuccess": true,
      "ShowWarning": true,
      "ShowError": true
    }
  },
  // optional, its a fileter for monitoring, can do it in code too. 
  "Monitoring": {
    "RefreshInterval": "00:00:02",
    "EnableDisk": true,
    "EnableNetwork": true,
    "ProcessNameFilter": [ "mysql", "nginx", "postgres", "emulator" ]
  },
  // Emulator database connections — leave AuthConnectionString empty to disable a type.
  "Emulators": {
    "TrinityCore": {
      "AuthConnectionString":      "",
      "CharacterConnectionString": "",
      "WorldConnectionString":     ""
    },
    "AzerothCore": {
      "AuthConnectionString":      "",
      "CharacterConnectionString": "",
      "WorldConnectionString":     ""
    },
    "CMaNGOS": {
      "AuthConnectionString":      "",
      "CharacterConnectionString": ""
    }
  },
  // DDNS — set Provider to NoIp | DuckDns | Cloudflare to activate.
  "Ddns": {
    "Provider":     "None",
    "Hostname":     "",
    "PollInterval": "00:15:00",
    "Username":     "",
    "Password":     "",
    "Token":        "",
    "ApiToken":     "",
    "ZoneId":       "",
    "RecordId":     ""
  },
  "AllowedHosts": "*"
}
