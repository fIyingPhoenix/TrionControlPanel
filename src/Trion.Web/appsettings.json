{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Trion": {
      "Folder": "Logs",
      "WriteToConsole": true,
      "WriteToFile": true,
      "ShowInfo": true,
      "ShowSuccess": true,
      "ShowWarning": true,
      "ShowError": true
    }
  },
  // optional, its a fileter for monitoring, can do it in code too. 
  "Monitoring": {
    "RefreshInterval": "00:00:02",
    "EnableDisk": true,
    "EnableNetwork": true,
    "ProcessNameFilter": [ "mysql", "nginx", "postgres", "emulator" ]
  },
  "AllowedHosts": "*"
}
