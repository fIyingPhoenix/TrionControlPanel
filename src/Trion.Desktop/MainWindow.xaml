<Window x:Class="Trion.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Trion.Desktop.ViewModels"
        xmlns:views="clr-namespace:Trion.Desktop.Views"
        mc:Ignorable="d"
        Title="Trion Control Panel"
        Icon="pack://application:,,,/Resources/Images/favicon.ico"
        MinWidth="900" MinHeight="600"
        Width="1180" Height="740"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource Background.Primary}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <!-- VM → View data templates -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SinglePlayerViewModel}">
            <views:SinglePlayerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DatabaseEditorViewModel}">
            <views:DatabaseEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DdnsViewModel}">
            <views:DdnsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <views:LogsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupportersViewModel}">
            <views:SupportersView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />   <!-- Title bar -->
            <RowDefinition Height="*" />    <!-- Body -->
            <RowDefinition Height="52" />   <!-- Server bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════
             TITLE BAR
             ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource Background.Secondary}"
                BorderBrush="{DynamicResource Border.Default}"
                BorderThickness="0,0,0,1">
            <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- logo / sidebar toggle -->
                    <ColumnDefinition Width="*" />     <!-- drag area -->
                    <ColumnDefinition Width="Auto" />  <!-- action buttons -->
                    <ColumnDefinition Width="Auto" />  <!-- chrome -->
                </Grid.ColumnDefinitions>

                <!-- Logo doubles as the sidebar toggle -->
                <Button Grid.Column="0"
                        Style="{StaticResource IconButtonStyle}"
                        Width="Auto"
                        Command="{Binding ToggleSidebarCommand}"
                        ToolTip="{Binding Loc[AppToggleSidebar]}"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Padding="10,0"
                        Margin="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Logo — OpacityMask tints the silhouette with Accent.Primary -->
                        <Rectangle Width="20" Height="20" Margin="0,0,8,0"
                                   Fill="{DynamicResource Accent.Primary}">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="pack://application:,,,/Resources/Images/TrionLogoNew.png"
                                            Stretch="Uniform" />
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="TRION"
                                   Style="{StaticResource H4Style}"
                                   Foreground="{DynamicResource Accent.Primary}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=" Control Panel"
                                   Style="{StaticResource H4Style}"
                                   Foreground="{DynamicResource Foreground.Secondary}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Action buttons: Theme + Notifications + Donation -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Margin="0,0,4,0">

                    <!-- Theme picker button -->
                    <Button x:Name="ThemeButton"
                            Style="{StaticResource IconButtonStyle}"
                            Command="{Binding ToggleThemePopupCommand}"
                            ToolTip="{Binding Loc[AppThemeChangeTooltip]}"
                            Margin="0,0,2,0">
                        <Path Data="{StaticResource Icon.Palette}"
                              Fill="{DynamicResource Foreground.Secondary}"
                              Width="16" Height="16" Stretch="Uniform" />
                    </Button>

                    <!-- Theme picker popup -->
                    <Popup IsOpen="{Binding IsThemePopupOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=ThemeButton}"
                           Placement="Bottom"
                           VerticalOffset="4"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource Background.Secondary}"
                                BorderBrush="{DynamicResource Border.Default}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                                                  Opacity="0.45" Color="#000000"
                                                  Direction="270" />
                            </Border.Effect>

                            <StackPanel Width="218">

                                <!-- Header -->
                                <TextBlock Text="{Binding Loc[AppThemeSection]}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource Foreground.Muted}"
                                           Margin="0,0,0,10" />

                                <!-- ── Mode row ── -->
                                <TextBlock Text="{Binding Loc[AppThemeMode]}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Foreground.Secondary}"
                                           Margin="0,0,0,6" />
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Light -->
                                    <Button Grid.Column="0"
                                            Height="30"
                                            Command="{Binding SetVariantCommand}"
                                            CommandParameter="Light">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="FontSize"  Value="12" />
                                                <Setter Property="Padding"   Value="8,0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsThemeDark}" Value="False">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource Accent.Primary}" />
                                                        <Setter Property="Foreground"
                                                                Value="{DynamicResource Accent.Foreground}" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource Icon.Sun}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Width="12" Height="12" Stretch="Uniform"
                                                  Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding Loc[AppThemeLight]}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <!-- Dark -->
                                    <Button Grid.Column="2"
                                            Height="30"
                                            Command="{Binding SetVariantCommand}"
                                            CommandParameter="Dark">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="FontSize"  Value="12" />
                                                <Setter Property="Padding"   Value="8,0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsThemeDark}" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource Accent.Primary}" />
                                                        <Setter Property="Foreground"
                                                                Value="{DynamicResource Accent.Foreground}" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource Icon.Moon}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Width="12" Height="12" Stretch="Uniform"
                                                  Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding Loc[AppThemeDark]}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- ── Color row ── -->
                                <TextBlock Text="{Binding Loc[AppThemeColor]}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Foreground.Secondary}"
                                           Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <!-- Trion Blue -->
                                    <Button Style="{StaticResource ColorSwatchStyle}"
                                            Command="{Binding SetColorCommand}"
                                            CommandParameter="TrionBlue"
                                            ToolTip="Trion Blue"
                                            Margin="4,0">
                                        <Grid Width="34" Height="34">
                                            <Ellipse Fill="#00D4FF" Width="26" Height="26" />
                                            <Ellipse Width="34" Height="34"
                                                     Stroke="#00D4FF" StrokeThickness="2.5"
                                                     Visibility="{Binding IsTrionBlueSelected,
                                                                  Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Button>

                                    <!-- Rose -->
                                    <Button Style="{StaticResource ColorSwatchStyle}"
                                            Command="{Binding SetColorCommand}"
                                            CommandParameter="Ocean"
                                            ToolTip="Rose"
                                            Margin="4,0">
                                        <Grid Width="34" Height="34">
                                            <Ellipse Fill="#F43F5E" Width="26" Height="26" />
                                            <Ellipse Width="34" Height="34"
                                                     Stroke="#F43F5E" StrokeThickness="2.5"
                                                     Visibility="{Binding IsOceanSelected,
                                                                  Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Button>

                                    <!-- Green -->
                                    <Button Style="{StaticResource ColorSwatchStyle}"
                                            Command="{Binding SetColorCommand}"
                                            CommandParameter="Green"
                                            ToolTip="Green"
                                            Margin="4,0">
                                        <Grid Width="34" Height="34">
                                            <Ellipse Fill="#4CAF50" Width="26" Height="26" />
                                            <Ellipse Width="34" Height="34"
                                                     Stroke="#4CAF50" StrokeThickness="2.5"
                                                     Visibility="{Binding IsGreenSelected,
                                                                  Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Button>

                                    <!-- Orange -->
                                    <Button Style="{StaticResource ColorSwatchStyle}"
                                            Command="{Binding SetColorCommand}"
                                            CommandParameter="Orange"
                                            ToolTip="Orange"
                                            Margin="4,0">
                                        <Grid Width="34" Height="34">
                                            <Ellipse Fill="#FF9800" Width="26" Height="26" />
                                            <Ellipse Width="34" Height="34"
                                                     Stroke="#FF9800" StrokeThickness="2.5"
                                                     Visibility="{Binding IsOrangeSelected,
                                                                  Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Button>

                                    <!-- Lila -->
                                    <Button Style="{StaticResource ColorSwatchStyle}"
                                            Command="{Binding SetColorCommand}"
                                            CommandParameter="Lila"
                                            ToolTip="Lila"
                                            Margin="4,0">
                                        <Grid Width="34" Height="34">
                                            <Ellipse Fill="#AB47BC" Width="26" Height="26" />
                                            <Ellipse Width="34" Height="34"
                                                     Stroke="#AB47BC" StrokeThickness="2.5"
                                                     Visibility="{Binding IsLilaSelected,
                                                                  Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Button>

                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Notifications button -->
                    <Button x:Name="NotificationButton"
                            Style="{StaticResource IconButtonStyle}"
                            Command="{Binding ShowNotificationsCommand}"
                            ToolTip="Notifications"
                            Margin="0,0,2,0">
                        <Grid Width="20" Height="20">
                            <Path Data="{StaticResource Icon.Bell}"
                                  Fill="{DynamicResource Foreground.Secondary}"
                                  Width="16" Height="16" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <!-- Badge — count of unread notifications -->
                            <Border CornerRadius="7"
                                    Background="#C42B1C"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    MinWidth="14" Height="14"
                                    Padding="3,0"
                                    Margin="0,0,-3,-3"
                                    Visibility="{Binding HasUnreadNotifications,
                                                 Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding UnreadCount}"
                                           FontSize="8" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Button>

                    <!-- Notifications popup -->
                    <Popup IsOpen="{Binding IsNotificationsPopupOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=NotificationButton}"
                           Placement="Bottom"
                           VerticalOffset="4"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource Background.Secondary}"
                                BorderBrush="{DynamicResource Border.Default}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Width="340">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                                                  Opacity="0.45" Color="#000000"
                                                  Direction="270" />
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Border Grid.Row="0"
                                        BorderBrush="{DynamicResource Border.Subtle}"
                                        BorderThickness="0,0,0,1"
                                        Padding="14,11">
                                    <TextBlock Text="{Binding Loc[AppNotificationsSection]}"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource Foreground.Muted}" />
                                </Border>

                                <!-- Entry list -->
                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding Notifications}"
                                         MaxHeight="320"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         Padding="0,4">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding"     Value="0" />
                                            <Setter Property="Background"  Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Root"
                                                                Background="{TemplateBinding Background}"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Root" Property="Background"
                                                                        Value="{DynamicResource Background.Tertiary}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="14,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding FormattedTime}"
                                                           FontFamily="Cascadia Code, Consolas"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource Accent.Primary}"
                                                           Margin="0,0,10,0"
                                                           VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Message}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource Foreground.Primary}"
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Footer: View all logs -->
                                <Border Grid.Row="2"
                                        BorderBrush="{DynamicResource Border.Subtle}"
                                        BorderThickness="0,1,0,0"
                                        Padding="10,8">
                                    <Button Content="{Binding Loc[AppNotificationsViewAll]}"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding ViewAllLogsCommand}"
                                            HorizontalAlignment="Left"
                                            Height="28" Padding="6,0"
                                            FontSize="12" />
                                </Border>
                            </Grid>
                        </Border>
                    </Popup>

                    <!-- ── Download progress indicator ── -->
                    <Button x:Name="DownloadButton"
                            Command="{Binding ShowDownloadProgressCommand}"
                            ToolTip="MySQL download in progress…"
                            Margin="0,0,2,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="BlinkSB">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="Opacity"
                                                        From="1.0" To="0.25"
                                                        Duration="0:0:0.65" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="BlinkSB" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Path Data="{StaticResource Icon.Download}"
                              Fill="{DynamicResource Accent.Primary}"
                              Width="16" Height="16" Stretch="Uniform" />
                    </Button>

                    <!-- Download popup -->
                    <Popup IsOpen="{Binding IsDownloadPopupOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=DownloadButton}"
                           Placement="Bottom"
                           VerticalOffset="4"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource Background.Secondary}"
                                BorderBrush="{DynamicResource Border.Default}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Width="310"
                                Padding="16,14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                                                  Opacity="0.45" Color="#000000"
                                                  Direction="270" />
                            </Border.Effect>
                            <StackPanel>

                                <!-- Header -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Path Data="{StaticResource Icon.Download}"
                                          Fill="{DynamicResource Accent.Primary}"
                                          Width="12" Height="12" Stretch="Uniform"
                                          VerticalAlignment="Center" Margin="0,0,7,0" />
                                    <TextBlock Text="MYSQL DOWNLOAD"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource Foreground.Muted}"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Progress bar -->
                                <ProgressBar Value="{Binding DownloadPercent}"
                                             Minimum="0" Maximum="100"
                                             Height="6"
                                             Foreground="{DynamicResource Accent.Primary}"
                                             Background="{DynamicResource Background.Tertiary}"
                                             Margin="0,0,0,10" />

                                <!-- Stats row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Size -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="SIZE"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource Foreground.Muted}"
                                                   Margin="0,0,0,3" />
                                        <TextBlock Text="{Binding DownloadedSize}"
                                                   FontFamily="Cascadia Code, Consolas"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Foreground.Secondary}" />
                                    </StackPanel>

                                    <!-- Speed -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="SPEED"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="{DynamicResource Foreground.Muted}"
                                                   Margin="0,0,0,3" />
                                        <TextBlock Text="{Binding DownloadSpeed}"
                                                   FontFamily="Cascadia Code, Consolas"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Accent.Primary}" />
                                    </StackPanel>

                                    <!-- Percent badge -->
                                    <Border Grid.Column="2"
                                            CornerRadius="5" Padding="8,3"
                                            Background="{DynamicResource Accent.Primary}"
                                            VerticalAlignment="Center">
                                        <TextBlock Foreground="White" FontSize="12" FontWeight="Bold">
                                            <Run Text="{Binding DownloadPercent}" /><Run Text="%" />
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- ETA row -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="ETA  "
                                               FontSize="10"
                                               Foreground="{DynamicResource Foreground.Muted}" />
                                    <TextBlock Text="{Binding DownloadEta}"
                                               FontFamily="Cascadia Code, Consolas"
                                               FontSize="10"
                                               Foreground="{DynamicResource Foreground.Secondary}" />
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Donation / Support -->
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding OpenDonationCommand}"
                            ToolTip="{Binding Loc[AppDonateTooltip]}"
                            Margin="0,0,4,0">
                        <Path Data="{StaticResource Icon.Donate}"
                              Fill="{DynamicResource Accent.Primary}"
                              Width="16" Height="16" Stretch="Uniform" />
                    </Button>

                    <!-- Thin separator -->
                    <Border Width="1"
                            Background="{DynamicResource Border.Default}"
                            Margin="0,8,4,8" />
                </StackPanel>

                <!-- Window chrome controls -->
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Minimize — filled dash -->
                    <Button Style="{StaticResource ChromeButtonStyle}"
                            Click="MinimizeButton_Click" ToolTip="{Binding Loc[AppWinMinimize]}">
                        <Path Data="M 3,11 H 13 V 13 H 3 Z"
                              Fill="{DynamicResource Foreground.Secondary}"
                              Width="16" Height="16" Stretch="Uniform" />
                    </Button>
                    <!-- Maximize / Restore — filled square ring -->
                    <Button Style="{StaticResource ChromeButtonStyle}"
                            Click="MaximizeButton_Click" ToolTip="{Binding Loc[AppWinMaximize]}">
                        <Path Data="M 3,3 H 21 V 21 H 3 Z M 5,7 V 19 H 19 V 7 Z"
                              Fill="{DynamicResource Foreground.Secondary}"
                              Width="16" Height="16" Stretch="Uniform" />
                    </Button>
                    <!-- Close — filled X -->
                    <Button Style="{StaticResource ChromeCloseButtonStyle}"
                            Click="CloseButton_Click" ToolTip="{Binding Loc[AppWinClose]}">
                        <Path Data="M 19,6.41 L 17.59,5 12,10.59 6.41,5 5,6.41 10.59,12 5,17.59 6.41,19 12,13.41 17.59,19 19,17.59 13.41,12 Z"
                              Fill="{DynamicResource Foreground.Secondary}"
                              Width="16" Height="16" Stretch="Uniform" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             BODY  (sidebar + content)
             ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar ── -->
            <Border Grid.Column="0"
                    x:Name="SidebarBorder"
                    Width="56"
                    Background="{DynamicResource Sidebar.Background}"
                    BorderBrush="{DynamicResource Border.Default}"
                    BorderThickness="0,0,1,0"
                    ClipToBounds="True">

                <!-- Animate sidebar width when IsSidebarCollapsed changes -->
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Width"
                                                             To="56" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Width"
                                                             To="220" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Main nav items -->
                    <ItemsControl Grid.Row="0"
                                  ItemsSource="{Binding NavItems}"
                                  Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Selection indicator wrapper -->
                                <Grid>
                                    <!-- 3px accent bar for selected item -->
                                    <Border x:Name="SelectBar"
                                            Width="3" HorizontalAlignment="Left"
                                            Background="{DynamicResource Sidebar.SelectedBorder}"
                                            Visibility="Collapsed" />

                                    <Button Style="{StaticResource NavItemStyle}"
                                            Command="{Binding DataContext.NavigateCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Margin="16,0,8,0">
                                            <Path Data="{Binding IconKey,
                                                         Converter={StaticResource ResourceKey}}"
                                                  Fill="{Binding Foreground,
                                                         RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Width="18" Height="18" Stretch="Uniform"
                                                  VerticalAlignment="Center" />
                                            <!-- Label — collapses when sidebar is narrow -->
                                            <TextBlock Text="{Binding Label}"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="13" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger
                                                                Binding="{Binding DataContext.IsSidebarCollapsed,
                                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>

                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter TargetName="SelectBar" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Account button pinned above Settings -->
                    <Button Grid.Row="1"
                            x:Name="AccountButton"
                            Style="{StaticResource NavItemStyle}"
                            Command="{Binding ToggleAccountPopupCommand}"
                            Foreground="{DynamicResource Foreground.Secondary}">
                        <StackPanel Orientation="Horizontal" Margin="16,0,8,0">
                            <Path Data="{StaticResource Icon.User}"
                                  Fill="{DynamicResource Foreground.Secondary}"
                                  Width="18" Height="18" Stretch="Uniform" />
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Sign In" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                                                <Setter Property="Text" Value="{Binding AccountUsername}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsGuest}" Value="True">
                                                <Setter Property="Text" Value="Guest" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!-- Account popup -->
                    <Popup IsOpen="{Binding IsAccountPopupOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=AccountButton}"
                           Placement="Top"
                           VerticalOffset="-4"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource Background.Secondary}"
                                BorderBrush="{DynamicResource Border.Default}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Width="280"
                                Padding="0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="28" ShadowDepth="6"
                                                  Opacity="0.40" Color="#000000" Direction="270" />
                            </Border.Effect>
                            <StackPanel>

                                <!-- ── Logged-in view ──────────────────────── -->
                                <StackPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibility}}">

                                    <!-- Header: avatar + name + badges -->
                                    <Border Background="{DynamicResource Background.Tertiary}"
                                            CornerRadius="10,10,0,0"
                                            Padding="16,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Avatar circle -->
                                            <Border Grid.Column="0"
                                                    Width="42" Height="42"
                                                    Background="{DynamicResource Accent.Primary}"
                                                    CornerRadius="21"
                                                    Margin="0,0,12,0">
                                                <Path Data="{StaticResource Icon.User}"
                                                      Fill="{DynamicResource Accent.Foreground}"
                                                      Width="18" Height="18" Stretch="Uniform" />
                                            </Border>
                                            <!-- Name + tier -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AccountUsername}"
                                                           Style="{StaticResource H4Style}"
                                                           Margin="0,0,0,5" />
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{DynamicResource Accent.Primary}"
                                                            CornerRadius="4" Padding="6,2" Margin="0,0,5,0"
                                                            Visibility="{Binding AccountRole, Converter={StaticResource NullToVisibility}}">
                                                        <TextBlock Text="{Binding AccountRole}"
                                                                   Foreground="{DynamicResource Accent.Foreground}"
                                                                   FontSize="10" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Background="{DynamicResource Background.Primary}"
                                                            BorderBrush="{DynamicResource Border.Default}"
                                                            BorderThickness="1"
                                                            CornerRadius="4" Padding="6,2"
                                                            Visibility="{Binding AccountApiTier, Converter={StaticResource NullToVisibility}}">
                                                        <TextBlock Text="{Binding AccountApiTier}"
                                                                   Foreground="{DynamicResource Foreground.Secondary}"
                                                                   FontSize="10" />
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Info rows -->
                                    <StackPanel Margin="16,12,16,12">
                                        <Grid Margin="0,0,0,5"
                                              Visibility="{Binding AccountCreatedAt, Converter={StaticResource NullToVisibility}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Member since"
                                                       Style="{StaticResource CaptionStyle}" />
                                            <TextBlock Grid.Column="1" Text="{Binding AccountCreatedAt}"
                                                       Style="{StaticResource CaptionStyle}"
                                                       FontWeight="SemiBold" />
                                        </Grid>
                                        <Grid Visibility="{Binding AccountLastLogin, Converter={StaticResource NullToVisibility}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Last login"
                                                       Style="{StaticResource CaptionStyle}" />
                                            <TextBlock Grid.Column="1" Text="{Binding AccountLastLogin}"
                                                       Style="{StaticResource CaptionStyle}"
                                                       FontWeight="SemiBold" />
                                        </Grid>
                                    </StackPanel>

                                    <Separator />
                                    <Border Padding="12,12">
                                        <Button Content="Sign Out"
                                                Command="{Binding LogoutCommand}"
                                                Style="{StaticResource DangerButtonStyle}"
                                                HorizontalAlignment="Stretch" />
                                    </Border>
                                </StackPanel>

                                <!-- ── Guest view ──────────────────────────── -->
                                <StackPanel Visibility="{Binding IsGuest, Converter={StaticResource BoolToVisibility}}"
                                            Margin="16,16">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Border Width="38" Height="38"
                                                Background="{DynamicResource Background.Tertiary}"
                                                BorderBrush="{DynamicResource Border.Default}"
                                                BorderThickness="1"
                                                CornerRadius="19"
                                                Margin="0,0,11,0">
                                            <Path Data="{StaticResource Icon.User}"
                                                  Fill="{DynamicResource Foreground.Muted}"
                                                  Width="16" Height="16" Stretch="Uniform" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Guest" Style="{StaticResource H4Style}" Margin="0,0,0,2" />
                                            <TextBlock Text="Not signed in" Style="{StaticResource CaptionStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="Sign in to unlock updates, downloads and cloud sync."
                                               Style="{StaticResource CaptionStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,12" />
                                    <Button Content="Sign In"
                                            Command="{Binding ShowLoginCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            HorizontalAlignment="Stretch" />
                                </StackPanel>

                                <!-- ── Not signed in ───────────────────────── -->
                                <StackPanel Margin="16,16">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsLoggedIn}" Value="False" />
                                                        <Condition Binding="{Binding IsGuest}"    Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="Sign in to Trion"
                                               Style="{StaticResource H4Style}"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="Access premium features and server downloads."
                                               Style="{StaticResource CaptionStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,12" />
                                    <Button Content="Sign In"
                                            Command="{Binding ShowLoginCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            HorizontalAlignment="Stretch" />
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Settings pinned at bottom -->
                    <Button Grid.Row="2"
                            Style="{StaticResource NavItemStyle}"
                            Command="{Binding NavigateToSettingsCommand}"
                            Foreground="{DynamicResource Foreground.Secondary}"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Margin="16,0,8,0">
                            <Path Data="{StaticResource Icon.Settings}"
                                  Fill="{DynamicResource Foreground.Secondary}"
                                  Width="18" Height="18" Stretch="Uniform" />
                            <TextBlock Text="{Binding Loc[NavSettings]}"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsSidebarCollapsed}"
                                                Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Content Area ── -->
            <Border Grid.Column="1"
                    Background="{DynamicResource Background.Primary}">
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             BOTTOM SERVER CONTROL BAR
             ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource Sidebar.Background}"
                BorderBrush="{DynamicResource Border.Default}"
                BorderThickness="0,1,0,0">
            <UniformGrid Columns="4">

                <!-- Database Server -->
                <Button Style="{StaticResource ServerBarButtonStyle}"
                        Tag="{Binding IsDatabaseRunning}"
                        Command="{Binding ToggleDatabaseServerCommand}"
                        ToolTip="{Binding Loc[TooltipServerDb]}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Power}"
                              Fill="{Binding Foreground,
                                     RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="13" Height="13" Stretch="Uniform"
                              Margin="0,0,8,0" />
                        <TextBlock Text="{Binding DatabaseButtonLabel}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Logon Server -->
                <Button Style="{StaticResource ServerBarButtonStyle}"
                        Tag="{Binding IsLogonRunning}"
                        Command="{Binding ToggleLogonServerCommand}"
                        ToolTip="{Binding Loc[TooltipServerLogon]}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Power}"
                              Fill="{Binding Foreground,
                                     RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="13" Height="13" Stretch="Uniform"
                              Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LogonButtonLabel}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- World Server -->
                <Button Style="{StaticResource ServerBarButtonStyle}"
                        Tag="{Binding IsWorldRunning}"
                        Command="{Binding ToggleWorldServerCommand}"
                        ToolTip="{Binding Loc[TooltipServerWorld]}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Power}"
                              Fill="{Binding Foreground,
                                     RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="13" Height="13" Stretch="Uniform"
                              Margin="0,0,8,0" />
                        <TextBlock Text="{Binding WorldButtonLabel}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                        
                <Button Style="{StaticResource ServerBarButtonStyle}"
                        IsEnabled="False"
                        ToolTip="{Binding Loc[TooltipServerWeb]}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Power}"
                              Fill="{Binding Foreground,
                                     RelativeSource={RelativeSource AncestorType=Button}}"
                              Width="13" Height="13" Stretch="Uniform"
                              Margin="0,0,8,0" />
                        <TextBlock Text="{Binding Loc[BTNStartWebsiteTextOFF]}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

            </UniformGrid>
        </Border>

    </Grid>
</Window>
