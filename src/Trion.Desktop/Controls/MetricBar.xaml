<UserControl x:Class="Trion.Desktop.Controls.MetricBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5" />
        </Grid.RowDefinitions>

        <!-- Label + value row -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource CaptionStyle}" />

            <TextBlock Grid.Column="1"
                       Style="{StaticResource SmallStyle}"
                       FontWeight="SemiBold">
                <TextBlock.Text>
                    <Binding Path="Value"
                             RelativeSource="{RelativeSource AncestorType=UserControl}"
                             StringFormat="{}{0:F0}%" />
                </TextBlock.Text>
            </TextBlock>
        </Grid>

        <!-- Progress track -->
        <Border Grid.Row="2"
                Height="6" CornerRadius="3"
                Background="{DynamicResource Background.Elevated}">
            <Border x:Name="Fill"
                    CornerRadius="3"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource Accent.Primary}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Width" Value="0" />
                    </Style>
                </Border.Style>
                <!-- Width driven by ActualWidth of parent * (Value/100) via code-behind sizing
                     In pure XAML, use a ProgressBar with custom template instead. -->
            </Border>
        </Border>

        <!-- Fallback: styled ProgressBar (reliable sizing) -->
        <ProgressBar Grid.Row="2"
                     Minimum="0" Maximum="100"
                     Height="6"
                     Value="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Foreground="{DynamicResource Accent.Primary}"
                     Background="{DynamicResource Background.Elevated}"
                     BorderThickness="0"
                     Style="{StaticResource ModernProgressBarStyle}" />

    </Grid>
</UserControl>
