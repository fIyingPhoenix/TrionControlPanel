<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="Background.Primary"   Color="#110E1A" />
    <SolidColorBrush x:Key="Background.Secondary" Color="#18131F" />
    <SolidColorBrush x:Key="Background.Tertiary"  Color="#211828" />
    <SolidColorBrush x:Key="Background.Elevated"  Color="#2A1E32" />

    <!-- Foregrounds -->
    <SolidColorBrush x:Key="Foreground.Primary"   Color="#EDE8F5" />
    <SolidColorBrush x:Key="Foreground.Secondary" Color="#9080A8" />
    <SolidColorBrush x:Key="Foreground.Muted"     Color="#604878" />
    <SolidColorBrush x:Key="Foreground.Disabled"  Color="#402E58" />

    <!-- Accent — Violet / Lila -->
    <SolidColorBrush x:Key="Accent.Primary"    Color="#AB47BC" />
    <SolidColorBrush x:Key="Accent.Hover"      Color="#CE93D8" />
    <SolidColorBrush x:Key="Accent.Pressed"    Color="#7B1FA2" />
    <SolidColorBrush x:Key="Accent.Foreground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Accent.Subtle"     Color="#1AAB47BC" />

    <!-- Borders -->
    <SolidColorBrush x:Key="Border.Default"    Color="#2A1E38" />
    <SolidColorBrush x:Key="Border.Subtle"     Color="#1A1020" />
    <SolidColorBrush x:Key="Border.Focus"      Color="#AB47BC" />

    <!-- Status -->
    <SolidColorBrush x:Key="Status.Running"    Color="#4CAF50" />
    <SolidColorBrush x:Key="Status.Stopped"    Color="#3A2848" />
    <SolidColorBrush x:Key="Status.Warning"    Color="#FFB347" />
    <SolidColorBrush x:Key="Status.Error"      Color="#FF4757" />

    <!-- Danger -->
    <SolidColorBrush x:Key="Danger.Primary"    Color="#FF4757" />
    <SolidColorBrush x:Key="Danger.Hover"      Color="#FF6B78" />

    <!-- Cards -->
    <SolidColorBrush x:Key="Card.Background"   Color="#18131F" />
    <SolidColorBrush x:Key="Card.Border"       Color="#2A1E38" />

    <!-- Sidebar -->
    <SolidColorBrush x:Key="Sidebar.Background"     Color="#0D0A14" />
    <SolidColorBrush x:Key="Sidebar.Selected"       Color="#1AAB47BC" />
    <SolidColorBrush x:Key="Sidebar.SelectedBorder" Color="#AB47BC" />
    <SolidColorBrush x:Key="Sidebar.SelectedText"   Color="#CE93D8" />
    <SolidColorBrush x:Key="Sidebar.HoverBg"        Color="#160F1E" />

    <!-- Inputs -->
    <SolidColorBrush x:Key="Input.Background"  Color="#211828" />
    <SolidColorBrush x:Key="Input.Border"      Color="#342048" />

    <!-- Focus glow -->
    <Color x:Key="Glow.Color">#AB47BC</Color>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollBar.Thumb"   Color="#342048" />
    <SolidColorBrush x:Key="ScrollBar.Track"   Color="#0E0914" />

    <!-- Tab underline -->
    <SolidColorBrush x:Key="Tab.Underline"     Color="#AB47BC" />

</ResourceDictionary>
