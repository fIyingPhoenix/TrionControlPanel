<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Rose Dark — neutral dark base + rose accent ───────────────── -->
    <SolidColorBrush x:Key="Background.Primary"   Color="#141414" />
    <SolidColorBrush x:Key="Background.Secondary" Color="#1C1C1C" />
    <SolidColorBrush x:Key="Background.Tertiary"  Color="#242424" />
    <SolidColorBrush x:Key="Background.Elevated"  Color="#2C2C2C" />

    <SolidColorBrush x:Key="Foreground.Primary"   Color="#E8E8E8" />
    <SolidColorBrush x:Key="Foreground.Secondary" Color="#9A9A9A" />
    <SolidColorBrush x:Key="Foreground.Muted"     Color="#6A6A6A" />
    <SolidColorBrush x:Key="Foreground.Disabled"  Color="#3E3E3E" />

    <!-- ── Accent — Rose ─────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Accent.Primary"    Color="#F43F5E" />
    <SolidColorBrush x:Key="Accent.Hover"      Color="#FB7185" />
    <SolidColorBrush x:Key="Accent.Pressed"    Color="#E11D48" />
    <SolidColorBrush x:Key="Accent.Foreground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Accent.Subtle"     Color="#1AF43F5E" />

    <!-- ── Borders ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Border.Default"    Color="#2E2E2E" />
    <SolidColorBrush x:Key="Border.Subtle"     Color="#1E1E1E" />
    <SolidColorBrush x:Key="Border.Focus"      Color="#F43F5E" />

    <!-- ── Status ────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Status.Running"    Color="#4CAF50" />
    <SolidColorBrush x:Key="Status.Stopped"    Color="#3E3E3E" />
    <SolidColorBrush x:Key="Status.Warning"    Color="#FF9800" />
    <SolidColorBrush x:Key="Status.Error"      Color="#F44336" />

    <!-- ── Danger ────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Danger.Primary"    Color="#F44336" />
    <SolidColorBrush x:Key="Danger.Hover"      Color="#EF5350" />

    <!-- ── Cards ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Card.Background"   Color="#1C1C1C" />
    <SolidColorBrush x:Key="Card.Border"       Color="#2E2E2E" />

    <!-- ── Sidebar ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Sidebar.Background"     Color="#0F0F0F" />
    <SolidColorBrush x:Key="Sidebar.Selected"       Color="#231515" />
    <SolidColorBrush x:Key="Sidebar.SelectedBorder" Color="#F43F5E" />
    <SolidColorBrush x:Key="Sidebar.SelectedText"   Color="#F43F5E" />
    <SolidColorBrush x:Key="Sidebar.HoverBg"        Color="#1A1A1A" />

    <!-- ── Inputs ────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Input.Background"  Color="#242424" />
    <SolidColorBrush x:Key="Input.Border"      Color="#383838" />

    <!-- ── Misc ──────────────────────────────────────────────────────── -->
    <Color x:Key="Glow.Color">#F43F5E</Color>
    <SolidColorBrush x:Key="ScrollBar.Thumb"   Color="#3A3A3A" />
    <SolidColorBrush x:Key="ScrollBar.Track"   Color="#181818" />
    <SolidColorBrush x:Key="Tab.Underline"     Color="#F43F5E" />

</ResourceDictionary>
