<UserControl x:Class="Trion.Desktop.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource Background.Primary}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Page header ── -->
        <Grid Grid.Row="0" Margin="28,24,28,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Loc[NavEventLog]}" Style="{StaticResource H1Style}" />
                <TextBlock Text="{Binding Loc[LogsCaption]}"
                           Style="{StaticResource CaptionStyle}"
                           Margin="0,3,0,0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="{Binding Loc[BtnClearAll]}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ClearAllCommand}"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- ── Log list ── -->
        <Border Grid.Row="1"
                Margin="28,0,28,28"
                Style="{StaticResource ElevatedCardStyle}"
                Padding="0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Column header -->
                <Grid Grid.Row="0"
                      Background="{DynamicResource Background.Tertiary}"
                      Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Loc[LogColTime]}"
                               Style="{StaticResource CaptionStyle}"
                               Padding="16,8,8,8" />
                    <TextBlock Grid.Column="1" Text="{Binding Loc[LogColDate]}"
                               Style="{StaticResource CaptionStyle}"
                               Padding="0,8,8,8" />
                    <TextBlock Grid.Column="2" Text="{Binding Loc[LogColEvent]}"
                               Style="{StaticResource CaptionStyle}"
                               Padding="0,8,8,8" />
                </Grid>

                <!-- Empty state -->
                <TextBlock Grid.Row="1"
                           Text="{Binding Loc[LogsEmpty]}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,40">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Entries.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Entries -->
                <ListView Grid.Row="1"
                          ItemsSource="{Binding Entries}"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding"     Value="0" />
                            <Setter Property="Background"  Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Border.Subtle}" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background"
                                                        Value="{DynamicResource Background.Tertiary}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding FormattedTime}"
                                           FontFamily="Cascadia Code, Consolas"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource Accent.Primary}"
                                           Padding="16,8,8,8"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding FormattedDate}"
                                           FontFamily="Cascadia Code, Consolas"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource Foreground.Muted}"
                                           Padding="0,8,8,8"
                                           VerticalAlignment="Center" />

                                <TextBlock Grid.Column="2"
                                           Text="{Binding Message}"
                                           FontSize="12.5"
                                           Foreground="{DynamicResource Foreground.Primary}"
                                           Padding="0,8,16,8"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</UserControl>
