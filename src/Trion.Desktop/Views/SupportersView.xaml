<UserControl x:Class="Trion.Desktop.Views.SupportersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Trion.Desktop.ViewModels"
             mc:Ignorable="d"
             Background="{DynamicResource Background.Primary}">

    <UserControl.Resources>

        <!-- ── Supporter card inside a tier group ──────────────────────────── -->
        <DataTemplate x:Key="SupporterCardTemplate">
            <Border Width="140" Height="70"
                    CornerRadius="8"
                    Margin="6"
                    BorderThickness="1"
                    BorderBrush="{Binding DataContext.TierBrush,
                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    Background="{Binding DataContext.CardBackground,
                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                <Grid Margin="10,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding Username}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Foreground.Primary}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="1"
                               Text="{Binding JoinedAt, StringFormat='Since {0}'}"
                               FontSize="10"
                               Foreground="{DynamicResource Foreground.Muted}" />
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ── Tier group (header + wrap of cards) ─────────────────────────── -->
        <DataTemplate x:Key="TierGroupTemplate">
            <StackPanel Margin="0,0,0,32">

                <!-- Tier header row -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tier icon -->
                    <Viewbox Grid.Column="0" Width="18" Height="18"
                             Margin="0,0,8,0" VerticalAlignment="Center">
                        <Path Data="{Binding IconKey,
                                    Converter={StaticResource ResourceKey}}"
                              Fill="{Binding TierBrush}"
                              Stretch="Uniform" />
                    </Viewbox>

                    <!-- Tier label -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding Label}"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{Binding TierBrush}" />

                    <!-- Divider line -->
                    <Rectangle Grid.Column="2"
                               Height="1"
                               Margin="12,0"
                               VerticalAlignment="Center"
                               Fill="{DynamicResource Border.Default}" />

                    <!-- Member count badge -->
                    <Border Grid.Column="3"
                            CornerRadius="10"
                            Padding="10,3"
                            Background="{Binding TierBrush}"
                            VerticalAlignment="Center">
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Background.Primary}"
                                   Text="{Binding Members.Count, StringFormat='{}{0} supporter(s)'}" />
                    </Border>
                </Grid>

                <!-- Royalty glow separator for legend/champion -->
                <Border Height="2"
                        Margin="0,0,0,14"
                        CornerRadius="1"
                        Visibility="{Binding IsRoyalty,
                                     Converter={StaticResource BoolToVisibility}}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0"   Color="Transparent"/>
                            <GradientStop Offset="0.3" Color="{Binding GlowColor}"/>
                            <GradientStop Offset="0.7" Color="{Binding GlowColor}"/>
                            <GradientStop Offset="1"   Color="Transparent"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Member cards in a wrapping panel -->
                <ItemsControl ItemsSource="{Binding Members}"
                              ItemTemplate="{StaticResource SupporterCardTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>

        <!-- Loading spinner -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Loading supporters…"
                       Style="{StaticResource SmallStyle}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Error state -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource SmallStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>
            <Button Content="Retry"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Main content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading,
                                   Converter={StaticResource InverseBoolToVisibility}}">
            <StackPanel Margin="28,24,28,28">

                <!-- Page header -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Supporters" Style="{StaticResource H1Style}"/>
                        <TextBlock Style="{StaticResource CaptionStyle}" Margin="0,3,0,0">
                            <Run Text="The people who keep Trion alive — "/>
                            <Run Text="{Binding TotalCount, StringFormat='{}{0} total'}"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource Accent.Primary}"/>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding RefreshCommand}"
                            VerticalAlignment="Bottom"
                            Style="{StaticResource SecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M 17.65,6.35 C 16.2,4.9 14.21,4 12,4
                                        A 8,8 0 0,0 4,12 A 8,8 0 0,0 12,20
                                        C 15.73,20 18.84,17.45 19.73,14 H 17.65
                                        C 16.83,16.33 14.61,18 12,18
                                        A 6,6 0 0,1 6,12 A 6,6 0 0,1 12,6
                                        C 13.66,6 15.14,6.69 16.22,7.78 L 13,11 H 20 V 4 Z"
                                  Fill="{DynamicResource Foreground.Secondary}"
                                  Width="14" Height="14" Stretch="Uniform"
                                  Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh"
                                       Foreground="{DynamicResource Foreground.Secondary}"
                                       FontSize="12"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Tier groups -->
                <ItemsControl ItemsSource="{Binding TierGroups}"
                              ItemTemplate="{StaticResource TierGroupTemplate}"/>

                <!-- Empty state (logged in but no supporters yet) -->
                <StackPanel HorizontalAlignment="Center"
                            Margin="0,40,0,0"
                            Visibility="{Binding HasNoSupporters,
                                         Converter={StaticResource BoolToVisibility}}">
                    <Path Data="{StaticResource Icon.Donate}"
                          Fill="{DynamicResource Foreground.Muted}"
                          Width="48" Height="48" Stretch="Uniform"
                          HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="No supporters yet"
                               Style="{StaticResource H3Style}"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource Foreground.Muted}"/>
                    <TextBlock Text="Be the first to support the project!"
                               Style="{StaticResource SmallStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
