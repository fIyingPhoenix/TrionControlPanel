<UserControl x:Class="Trion.Desktop.Views.InstallerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource Background.Primary}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">

            <!-- ── Page header ── -->
            <TextBlock Text="{Binding Loc[NavInstaller]}"
                       Style="{StaticResource H1Style}" Margin="0,0,0,4" />
            <TextBlock Text="{Binding Loc[InstallerCaption]}"
                       Style="{StaticResource CaptionStyle}" Margin="0,0,0,28" />

            <!-- ── Progress / Status card ── -->
            <Border Style="{StaticResource ElevatedCardStyle}" Padding="20" Margin="0,0,0,24">
                <Grid>

                <!-- IDLE: simple hint text -->
                <TextBlock Text="{Binding Loc[InstallerActionDesc]}"
                           Style="{StaticResource HintStyle}"
                           TextWrapping="Wrap"
                           Visibility="{Binding IsInstalling, Converter={StaticResource InverseBoolToVisibility}}" />

                <!-- ACTIVE: phase label, progress bar, status line, speed, cancel -->
                <Grid Visibility="{Binding IsInstalling, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10"   />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6"    />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Row 0: phase label + percent + cancel -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"    />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16"   />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding ProgressPhase}"
                                   Style="{StaticResource SectionLabelStyle}" />

                        <TextBlock Grid.Column="1"
                                   Text="{Binding ProgressValue, StringFormat={}{0:F0}%}"
                                   Style="{StaticResource CaptionStyle}"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="3"
                                Content="{Binding Loc[BtnCancel]}"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="80" />
                    </Grid>

                    <!-- Row 2: progress bar -->
                    <ProgressBar Grid.Row="2"
                                 Value="{Binding ProgressValue}"
                                 Minimum="0" Maximum="100"
                                 Style="{StaticResource ModernProgressBarStyle}"
                                 Foreground="{DynamicResource Accent.Primary}" />

                    <!-- Row 4: status text + speed -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"    />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding ProgressStatus}"
                                   Style="{StaticResource CaptionStyle}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Column="1"
                                   Text="{Binding SpeedText}"
                                   Style="{StaticResource CaptionStyle}"
                                   Foreground="{DynamicResource Accent.Primary}"
                                   FontWeight="SemiBold" />
                    </Grid>
                </Grid>

                </Grid>
            </Border>

            <!-- ── Expansion rows ── -->
            <TextBlock Text="{Binding Loc[LBLEnableExpansions]}"
                       Style="{StaticResource SectionLabelStyle}"
                       Margin="0,0,0,12" />

            <ItemsControl ItemsSource="{Binding Expansions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ElevatedCardStyle}"
                                Padding="16,14" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- Status dot -->
                                    <ColumnDefinition Width="Auto" />
                                    <!-- Name + version info -->
                                    <ColumnDefinition Width="*"    />
                                    <!-- Action buttons -->
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Status dot -->
                                <Ellipse Grid.Column="0"
                                         Width="10" Height="10"
                                         VerticalAlignment="Center"
                                         Margin="0,0,14,0"
                                         Fill="{Binding IsInstalled, Converter={StaticResource StatusToColor}}" />

                                <!-- Name + version info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">

                                    <TextBlock Text="{Binding DisplayName}"
                                               Style="{StaticResource BodyStyle}"
                                               FontWeight="SemiBold" />

                                    <!-- Installed state: local + latest versions -->
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,3,0,0"
                                                Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Style="{StaticResource CaptionStyle}">
                                            <Run Text="Local: " />
                                            <Run Text="{Binding LocalVersion}" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CaptionStyle}" Margin="16,0,0,0">
                                            <Run Text="Latest: " />
                                            <Run Text="{Binding LatestVersion}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Not-installed state: just show latest available -->
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,3,0,0"
                                                Visibility="{Binding NotIsInstalled, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Style="{StaticResource CaptionStyle}"
                                                   Foreground="{DynamicResource Foreground.Muted}">
                                            <Run Text="Not installed  ·  Latest: " />
                                            <Run Text="{Binding LatestVersion}" />
                                        </TextBlock>
                                    </StackPanel>

                                </StackPanel>

                                <!-- Action buttons — Install (when not installed) -->
                                <Button Grid.Column="2"
                                        Content="{Binding DataContext.Loc[BtnInstall],
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Command="{Binding DataContext.InstallCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Width="90"
                                        Visibility="{Binding NotIsInstalled, Converter={StaticResource BoolToVisibility}}" />

                                <!-- Repair + Uninstall (when installed) -->
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibility}}">

                                    <Button Content="{Binding DataContext.Loc[BtnRepair],
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Command="{Binding DataContext.RepairCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Width="90" Margin="0,0,8,0" />

                                    <Button Content="{Binding DataContext.Loc[BtnUninstall],
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Command="{Binding DataContext.UninstallCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Width="90" />

                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
