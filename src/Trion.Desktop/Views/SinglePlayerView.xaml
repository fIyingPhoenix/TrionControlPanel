<UserControl x:Class="Trion.Desktop.Views.SinglePlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Trion.Desktop.ViewModels"
             xmlns:conv="clr-namespace:Trion.Desktop.Infrastructure.Converters"
             mc:Ignorable="d"
             Background="{DynamicResource Background.Primary}">

    <UserControl.Resources>
        <conv:BoolToStringConverter x:Key="EnabledLabel"
                                    TrueValue="● Enabled" FalseValue="○ Disabled" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,28">

            <!-- ── Page header ── -->
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{Binding Loc[TabSPPTitle]}" Style="{StaticResource H1Style}" />
                    <TextBlock Text="{Binding Loc[SPPCaption]}"
                               Style="{StaticResource CaptionStyle}"
                               Margin="0,3,0,0" />
                </StackPanel>
            </Grid>

            <!-- ── Emulator cards — full-width stack ── -->
            <ItemsControl ItemsSource="{Binding Emulators}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:EmulatorCardViewModel}">

                        <Border Margin="0,0,0,14"
                                Style="{StaticResource ElevatedCardStyle}"
                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6" />   <!-- accent strip -->
                                    <ColumnDefinition Width="*" />   <!-- card body -->
                                </Grid.ColumnDefinitions>

                                <!-- Accent strip -->
                                <Border Grid.Column="0" CornerRadius="10,0,0,10"
                                        Background="{Binding AccentBrush}" />

                                <!-- ── Card body ── -->
                                <Grid Grid.Column="1" Margin="24,22,24,22">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />  <!-- main content row -->
                                        <RowDefinition Height="Auto" />  <!-- progress panel -->
                                    </Grid.RowDefinitions>

                                    <!-- ── Main content: info (left) + buttons (right) ── -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />       <!-- info -->
                                            <ColumnDefinition Width="24" />      <!-- gutter -->
                                            <ColumnDefinition Width="200" />     <!-- buttons -->
                                        </Grid.ColumnDefinitions>

                                        <!-- ══ LEFT: info column ══ -->
                                        <StackPanel Grid.Column="0">

                                            <!-- Header: icon + name + status pill -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Icon badge -->
                                                <Grid Grid.Column="0" Width="44" Height="44" Margin="0,0,14,0">
                                                    <Border CornerRadius="10" Opacity="0.15"
                                                            Background="{Binding AccentBrush}" />
                                                    <Path Data="{StaticResource Icon.Controller}"
                                                          Fill="{Binding AccentBrush}"
                                                          Width="22" Height="22" Stretch="Uniform" />
                                                </Grid>

                                                <!-- Name + short name -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               Style="{StaticResource H3Style}" />
                                                    <TextBlock Text="{Binding ShortName}"
                                                               Style="{StaticResource CaptionStyle}"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>

                                                <!-- Status pill -->
                                                <Border Grid.Column="2" CornerRadius="10" Padding="10,4"
                                                        VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"
                                                                    Value="{DynamicResource Background.Elevated}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                    <Setter Property="Background"
                                                                            Value="{DynamicResource Status.Running}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text"     Value="Not Installed" />
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource Foreground.Secondary}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                        <Setter Property="Text"     Value="Installed" />
                                                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>

                                            <!-- Divider under header -->
                                            <Separator Margin="0,16,0,16" />

                                            <!-- Version row -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="32" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Installed version -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="INSTALLED"
                                                               Style="{StaticResource SectionLabelStyle}"
                                                               Margin="0,0,0,5" />
                                                    <TextBlock Text="{Binding InstalledVersion}"
                                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                                               FontSize="13">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource Foreground.Primary}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                                        <Setter Property="Foreground"
                                                                                Value="{DynamicResource Status.Warning}" />
                                                                        <DataTrigger.EnterActions>
                                                                            <BeginStoryboard x:Name="VersionBlink">
                                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                     From="1.0" To="0.2"
                                                                                                     Duration="0:0:0.8" />
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </DataTrigger.EnterActions>
                                                                        <DataTrigger.ExitActions>
                                                                            <RemoveStoryboard BeginStoryboardName="VersionBlink" />
                                                                        </DataTrigger.ExitActions>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Update arrow (API emulators only) -->
                                                <TextBlock Grid.Column="1"
                                                           Text="↑" FontSize="18" FontWeight="Bold"
                                                           Foreground="{DynamicResource Status.Running}"
                                                           VerticalAlignment="Bottom"
                                                           HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding HasUpdate}"    Value="True" />
                                                                        <Condition Binding="{Binding HasApiInstall}" Value="True" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Latest version (API emulators only) -->
                                                <StackPanel Grid.Column="2"
                                                            Visibility="{Binding HasApiInstall,
                                                                         Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="LATEST"
                                                               Style="{StaticResource SectionLabelStyle}"
                                                               Margin="0,0,0,5" />
                                                    <TextBlock Text="{Binding LatestVersion}"
                                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource Foreground.Secondary}" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- Install path (Custom Core only) -->
                                            <TextBlock Text="INSTALL PATH"
                                                       Style="{StaticResource SectionLabelStyle}"
                                                       Margin="0,16,0,6"
                                                       Visibility="{Binding HasApiInstall,
                                                                    Converter={StaticResource InverseBoolToVisibility}}" />
                                            <Grid Visibility="{Binding HasApiInstall,
                                                               Converter={StaticResource InverseBoolToVisibility}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Background="{DynamicResource Background.Primary}"
                                                        BorderBrush="{DynamicResource Border.Default}"
                                                        BorderThickness="1" CornerRadius="6"
                                                        Padding="10,6">
                                                    <TextBlock Text="{Binding InstallPath}"
                                                               Style="{StaticResource CaptionStyle}"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding InstallPath}" />
                                                </Border>
                                                <Button Grid.Column="2"
                                                        Content="…"
                                                        Command="{Binding BrowseInstallPathCommand}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Width="36" Height="32"
                                                        FontSize="15"
                                                        ToolTip="Choose folder" />
                                            </Grid>

                                        </StackPanel>

                                        <!-- ══ RIGHT: button column ══ -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">

                                            <!-- Install (hidden once installed) -->
                                            <Button Content="{Binding DataContext.Loc[BtnInstall],
                                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Command="{Binding InstallCommand}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    Height="36"
                                                    Margin="0,0,0,8"
                                                    Visibility="{Binding IsInstalled,
                                                                 Converter={StaticResource InverseBoolToVisibility}}" />

                                            <!-- Update (only when HasUpdate) -->
                                            <Button Content="⬆  Update"
                                                    Command="{Binding UpdateCommand}"
                                                    HorizontalAlignment="Stretch"
                                                    Height="36"
                                                    Margin="0,0,0,8"
                                                    Visibility="{Binding HasUpdate,
                                                                 Converter={StaticResource BoolToVisibility}}">
                                                <Button.Style>
                                                    <Style TargetType="Button"
                                                           BasedOn="{StaticResource PrimaryButtonStyle}">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource Status.Running}" />
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Repair -->
                                            <Button Content="{Binding DataContext.Loc[BtnRepair],
                                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Command="{Binding RepairCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    Height="36"
                                                    Margin="0,0,0,8" />

                                            <!-- Uninstall -->
                                            <Button Content="{Binding DataContext.Loc[BtnUninstall],
                                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Command="{Binding UninstallCommand}"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    HorizontalAlignment="Stretch"
                                                    Height="36"
                                                    Margin="0,0,0,12" />

                                            <!-- Separator -->
                                            <Separator Margin="0,0,0,12" />

                                            <!-- Enable / Disable -->
                                            <Button Command="{Binding ToggleEnabledCommand}"
                                                    HorizontalAlignment="Stretch"
                                                    Height="36">
                                                <Button.Style>
                                                    <Style TargetType="Button"
                                                           BasedOn="{StaticResource SecondaryButtonStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Background"
                                                                        Value="{DynamicResource Status.Running}" />
                                                                <Setter Property="Foreground" Value="#FFFFFF" />
                                                                <Setter Property="BorderThickness" Value="0" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="{Binding IsEnabled,
                                                                   Converter={StaticResource EnabledLabel}}"
                                                           FontSize="13" />
                                            </Button>

                                        </StackPanel>
                                    </Grid>

                                    <!-- ── Progress panel (shown when IsWorking) ── -->
                                    <Border Grid.Row="1"
                                            Margin="0,18,0,0"
                                            Background="{DynamicResource Background.Primary}"
                                            CornerRadius="8"
                                            Padding="16,14"
                                            Visibility="{Binding IsWorking,
                                                         Converter={StaticResource BoolToVisibility}}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="10" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Top row: phase + speed + % + cancel -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding PhaseLabel}"
                                                               FontWeight="SemiBold" FontSize="13"
                                                               Foreground="{DynamicResource Foreground.Primary}"
                                                               Margin="0,0,10,0" />
                                                    <TextBlock Text="{Binding SpeedText}"
                                                               Style="{StaticResource MonoStyle}"
                                                               Foreground="{DynamicResource Accent.Primary}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding SpeedText,
                                                                            Converter={StaticResource NullToVisibility}}" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Progress, StringFormat={}{0:F0}%}"
                                                           Style="{StaticResource MonoStyle}"
                                                           Foreground="{DynamicResource Foreground.Secondary}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,14,0" />

                                                <Button Grid.Column="2"
                                                        Content="Cancel"
                                                        Command="{Binding CancelCommand}"
                                                        Style="{StaticResource DangerButtonStyle}"
                                                        Padding="14,4"
                                                        FontSize="12" />
                                            </Grid>

                                            <!-- Progress bar -->
                                            <ProgressBar Grid.Row="2"
                                                         Value="{Binding Progress}"
                                                         Minimum="0" Maximum="100"
                                                         Height="8"
                                                         Foreground="{Binding AccentBrush}"
                                                         Background="{DynamicResource Background.Elevated}"
                                                         BorderThickness="0"
                                                         Style="{StaticResource ModernProgressBarStyle}" />

                                            <!-- Status text -->
                                            <TextBlock Grid.Row="4"
                                                       Text="{Binding StatusText}"
                                                       Style="{StaticResource CaptionStyle}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding StatusText,
                                                                    Converter={StaticResource NullToVisibility}}" />
                                        </Grid>
                                    </Border>

                                </Grid>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
